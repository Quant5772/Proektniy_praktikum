{
  "manifest_version": 3,
  "name": "TabMind",
  "version": "1.0.0",
  "description": "Tab manager with auto-categorization, smart snooze.",
  "permissions": ["tabs", "storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabMind"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
